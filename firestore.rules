rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to verify if the user is authenticated and is staff or admin
    function isStaffOrAdmin() {
      return request.auth != null && (
        request.auth.token.role in ['staff', 'admin'] ||
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['staff', 'admin']
      );
    }

    // 1. gates collection: public read, write restricted to staff/admin
    match /gates/{gateId} {
      allow read: if true;
      allow write: if isStaffOrAdmin();
    }

    // 2. facilities collection: public read, write restricted to staff/admin
    match /facilities/{facilityId} {
      allow read: if true;
      allow write: if isStaffOrAdmin();
    }

    // 3. knowledgeBase collection: public read, write restricted to staff/admin
    match /knowledgeBase/{faqId} {
      allow read: if true;
      allow write: if isStaffOrAdmin();
    }

    // 4. incidents collection: public read, write restricted to staff/admin
    match /incidents/{incidentId} {
      allow read: if true;
      allow write: if isStaffOrAdmin();
    }

    // 5. feedback collection: public read, write restricted to staff/admin
    match /feedback/{feedbackId} {
      allow read: if true;
      allow write: if isStaffOrAdmin();
    }

    // 6. volunteers collection: public read, write restricted to staff/admin
    match /volunteers/{volunteerId} {
      allow read: if true;
      allow write: if isStaffOrAdmin();
    }

    // User profiles: read by anyone signed in, write by self or admin
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || isStaffOrAdmin());
    }
  }
}
