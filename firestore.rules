rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to retrieve the user's role from the users collection document
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    // Helper to verify if the authenticated user has a specified role (via custom claims or doc)
    function hasRole(roles) {
      return request.auth != null && (
        request.auth.token.role in roles ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         getUserRole() in roles)
      );
    }

    // 1. gates collection: public read, write restricted to organizers & admins
    match /gates/{gateId} {
      allow read: if true;
      allow write: if hasRole(['organizer', 'admin']);
    }

    // 2. facilities collection: public read, write restricted to admins
    match /facilities/{facilityId} {
      allow read: if true;
      allow write: if hasRole(['admin']);
    }

    // 3. knowledgeBase collection: public read, write restricted to staff & admins
    match /knowledgeBase/{faqId} {
      allow read: if true;
      allow write: if hasRole(['staff', 'admin']);
    }

    // 4. incidents collection: public read, create by any authenticated user, update/delete by staff & admins
    match /incidents/{incidentId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if hasRole(['staff', 'admin']);
    }

    // 5. feedback collection: public read, create by any authenticated user, update/delete by admins
    match /feedback/{feedbackId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if hasRole(['admin']);
    }

    // 6. volunteers collection: read by staff & admins, write by admins
    match /volunteers/{volunteerId} {
      allow read: if hasRole(['staff', 'admin']);
      allow write: if hasRole(['admin']);
    }

    // User profiles: read by anyone signed in, write by self or admin
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && (request.auth.uid == userId || hasRole(['admin']));
    }
  }
}
